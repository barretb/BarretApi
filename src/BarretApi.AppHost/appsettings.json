{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning"
    }
  },
  "Parameters": {
    "gibs-base-url": "https://wvs.earthdata.nasa.gov/api/v1/snapshot",
    "gibs-default-layer": "MODIS_Terra_CorrectedReflectance_TrueColor",
    "gibs-bbox-south": "38.40",
    "gibs-bbox-west": "-84.82",
    "gibs-bbox-north": "42.32",
    "gibs-bbox-east": "-80.52",
    "gibs-image-width": "1024",
    "gibs-image-height": "768",
    "scheduled-social-post-max-batch-size": "100",
    "scheduled-social-post-table-storage-table-name": "scheduledsocialposts",
    "scheduled-social-post-table-storage-partition-key": "scheduled-social-post",
    "github-api-base-url": "https://api.github.com",
    "github-oauth-base-url": "https://github.com",
    "github-token-storage-table-name": "githubtokens",
    "github-repo-storage-table-name": "githubrepositories"
  }
}
